PORT=3000
NODE_ENV=development

# Comma-separated allowed origins for CORS
CLIENT_URL=http://localhost:5173,https://www.vidyank.com,https://vidyank.com

MONGODB_URI=
JWT_SECRET=

# Production cookie domain (shared between www + api subdomains)
# COOKIE_DOMAIN=.vidyank.com

# AWS / S3 / CloudFront
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=learningplatforn

# CloudFront base URL used to build public video/thumbnail URLs from stored keys
CDN_URL=https://cdn.vidyank.com
